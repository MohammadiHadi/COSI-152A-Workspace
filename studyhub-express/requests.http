@noteId = paste_note_id_here

### Register a new user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test Student",
  "email": "student@example.com",
  "password": "password123"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "student@example.com",
  "password": "password123"
}

### Get all public notes
GET {{baseUrl}}/notes

### Get all notes as logged-in user
GET {{baseUrl}}/notes
Authorization: Bearer {{token}}

### Create a valid note
POST {{baseUrl}}/notes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "React State",
  "course": "COSI 152A",
  "content": "React state helps components remember and update data.",
  "tags": ["react", "state"]
}

### Create validation test: missing title
POST {{baseUrl}}/notes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "course": "COSI 152A",
  "content": "This request should fail because title is missing.",
  "tags": ["validation"]
}

### Create validation test: missing content
POST {{baseUrl}}/notes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Missing Content Test",
  "course": "COSI 152A",
  "tags": ["validation"]
}

### Create validation test: tags must be an array
POST {{baseUrl}}/notes
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Invalid Tags Test",
  "course": "COSI 152A",
  "content": "This should fail because tags is not an array.",
  "tags": "react"
}

### Get one note by ID
GET {{baseUrl}}/notes/{{noteId}}

### Get one note by ID as logged-in user
GET {{baseUrl}}/notes/{{noteId}}
Authorization: Bearer {{token}}

### Invalid ID test
GET {{baseUrl}}/notes/123

### Update a note
PATCH {{baseUrl}}/notes/{{noteId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Updated React State",
  "course": "COSI 152A",
  "content": "This note has been updated.",
  "tags": ["react", "state", "updated"]
}

### Update only likes
PATCH {{baseUrl}}/notes/{{noteId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "likes": 1
}

### Update validation test: empty title
PATCH {{baseUrl}}/notes/{{noteId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": ""
}

### Delete a note
DELETE {{baseUrl}}/notes/{{noteId}}
Authorization: Bearer {{token}}

### Delete without token should fail
DELETE {{baseUrl}}/notes/{{noteId}}